# Overworld — environment template.
# Copy to .env (gitignored) and fill in. NEVER commit a real key.
#   cp .env.example .env

# Required: the brain reads this at first call (server/brain.py -> AsyncAnthropic()).
# Without it the server still boots and serves the glass, but the seed loop
# (interview -> decompose -> minis -> synth -> ship) fails on auth.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults live in server/brain.py).
# OVERWORLD_MODEL_ORCH=claude-sonnet-4-6
# OVERWORLD_MODEL_WORKER=claude-haiku-4-5-20251001
